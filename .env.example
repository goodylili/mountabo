# mountabo — single source of truth for local config.
# Copy to .env at the repo root and fill in the GitHub App credentials.
# Read by the Go backend (internal/config) and the Next frontend (next.config.ts).

# ── GitHub App OAuth (user-to-server web flow) ──
# Create a GitHub App at https://github.com/settings/apps with these permissions:
#   Repository: Contents (R/W), Administration (R/W, for deploy keys),
#               Secrets (R/W), Workflows (W), Metadata (R, mandatory).
# Enable "Request user authorization (OAuth) during installation" and set the
# callback URL to http://localhost:4321/api/github/callback, then generate a
# client secret.
# Client ID is public — used by BOTH frontend and backend.
# Client secret is used by the BACKEND ONLY (never sent to the browser).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── AI command helper (terminal page) ──
# Anthropic API key for the "ask the AI helper" feature on the terminal page.
# Optional: leave empty to run mountabo without AI suggestions (the terminal
# page then shows a hint to set this). Backend only; never sent to the browser.
# Get a key at https://console.anthropic.com/.
ANTHROPIC_API_KEY=
# Optional: override the Claude model used for suggestions (default claude-sonnet-4-6).
# MOUNTABO_AI_MODEL=

# ── Wiring ──
# URL the frontend uses to reach the Go backend's exchange endpoint.
MOUNTABO_BACKEND=http://localhost:7778
# Address the Go backend listens on (loopback-only; local-first).
MOUNTABO_HTTP_ADDR=127.0.0.1:7778
