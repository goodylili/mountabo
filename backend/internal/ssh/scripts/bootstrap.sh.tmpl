#!/usr/bin/env bash
# mountabo server bootstrap — fresh Ubuntu -> Docker-ready.
# Rendered and run by mountabo over SSH as root. Fully non-interactive.
#
# It does NOT modify /etc/ssh/sshd_config: root login and password
# authentication are left exactly as the provider set them, so the operator
# keeps whatever access they already had.
#
# Order:
#   1. FIRST, create the mountabo user + install SSH keys (mountabo's + the
#      operator's) + sudo, so key-based access exists immediately.
#   2. THEN the minimal system work: apt update, timezone, Docker. No firewall,
#      fail2ban, or other opinionated policy — the server's posture is left to
#      the operator.
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive

log() { echo "==> $*"; }

log "creating user {{.User}}"
if ! id -u {{.User}} >/dev/null 2>&1; then
  adduser --disabled-password --gecos "" {{.User}}
fi
usermod -aG sudo {{.User}}
echo '{{.User}} ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/90-mountabo
chmod 440 /etc/sudoers.d/90-mountabo

log "installing ssh keys for {{.User}} (mountabo + your own access)"
install -d -m 700 -o {{.User}} -g {{.User}} /home/{{.User}}/.ssh
cat > /home/{{.User}}/.ssh/authorized_keys <<'MOUNTABO_AUTHORIZED_KEY'
{{.PublicKey}}{{if .UserPublicKey}}
{{.UserPublicKey}}{{end}}
MOUNTABO_AUTHORIZED_KEY
chown {{.User}}:{{.User}} /home/{{.User}}/.ssh/authorized_keys
chmod 600 /home/{{.User}}/.ssh/authorized_keys

log "updating package lists"
apt-get update -y

log "upgrading system (this can take several minutes)"
apt-get upgrade -y

log "installing base packages"
apt-get install -y curl ca-certificates

log "setting timezone to {{.Timezone}}"
timedatectl set-timezone '{{.Timezone}}'

log "installing docker"
curl -fsSL https://get.docker.com | sh
usermod -aG docker {{.User}}
apt-get install -y docker-compose-plugin

log "verifying docker"
docker --version
docker compose version

log "base setup complete (ssh login left unchanged)"
# Optional, opt-in steps the operator chose are appended below by mountabo,
# followed by a final "done" line.
