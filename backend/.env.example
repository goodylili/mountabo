# GitHub App OAuth credentials (user-to-server web flow).
# Create a GitHub App at https://github.com/settings/apps with these permissions:
#   Repository: Contents (R/W), Administration (R/W, for deploy keys),
#               Secrets (R/W), Workflows (W), Metadata (R, mandatory).
# Enable "Request user authorization (OAuth) during installation" and generate a
# client secret. The client ID is also needed by the frontend to build the
# authorize URL; the client secret stays here on the backend only.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Local API listen address. Loopback-only by default — mountabo is local-first.
MOUNTABO_HTTP_ADDR=127.0.0.1:7777
